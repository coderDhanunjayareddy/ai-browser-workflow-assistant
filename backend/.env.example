# Copy this file to .env and fill in values before running.

# docker-compose maps host port 5433 to container port 5432.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/ai_browser_assist

# Gemini API key.
GEMINI_API_KEY=your-gemini-api-key

# Model to use.
GEMINI_MODEL=gemini-2.5-flash
