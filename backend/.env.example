# Copy this file to .env and fill in values before running.

# docker-compose maps host port 5433 to container port 5432.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/ai_browser_assist

# AI provider: openrouter or gemini.
AI_PROVIDER=openrouter

# OpenRouter API key.
OPENROUTER_API_KEY=your-openrouter-api-key

# OpenRouter model to use.
OPENROUTER_MODEL=openai/gpt-4o-mini

# Gemini API key.
GEMINI_API_KEY=your-gemini-api-key

# Model to use.
GEMINI_MODEL=gemini-2.5-flash
